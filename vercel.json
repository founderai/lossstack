{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "lossstack.com"
        }
      ],
      "destination": "https://www.lossstack.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/billing/cron/referral-qualification",
      "schedule": "0 6 * * *"
    }
  ]
}
